<tr>
  <td><%= meeting.name %>
    <ul>
      <li>start date:
        <% meeting.project.schools.each { |s| %>
          <div><%= meeting.start_date.in_time_zone(s.time_zone) %> @
               <%= s.time_zone %></div>
        <% } %>
      <li>memo: <%= meeting.memo %></li>
    </li>
  </td>
  <td><%= link_to "edit", edit_td_meeting_path(meeting),
                  class: "btn btn-success btn-sm" %>
  </td>
  <td><%= link_to "delete", td_meeting_path(meeting), 
                  class: "btn btn-secondary btn-sm",
                  data: { turbo_confirm: "Are you sure?",
                          turbo_method: :delete }  %>
  </td>
</tr>
