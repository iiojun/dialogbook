<%= render "nav" %>
<h1>Dialogbook's Dashboard</h1>
<% if @certificates != nil %>
<h2>Certificates list</h2>
<p>
  <% if @certificates.length == 0 %>
    No certificates
  <% else %>
    <table class="table table-sm table-striped">
      <%= render "tableheader" %>
      <%= render partial: "cert", collection: @certificates, as: :cert %>
    </table>
    <%= paginate @certificates %>
  <% end %>
</p>
<% end %>

