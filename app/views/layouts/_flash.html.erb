<% { notice: "info", alert: "warning" }.each do |type, bs_class| %>
  <% if flash[type].present? %>
    <div class="alert alert-<%= bs_class %> alert-dismissible fade show"
         role="alert" data-controller="flash">

      <%= flash[type] %>

      <button type="button" class="btn-close"
              data-bs-dismiss="alert" aria-label="dismiss">
      </button>
    </div>
  <% end %>
<% end %>
