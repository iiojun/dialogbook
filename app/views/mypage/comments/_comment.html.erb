<div id="<%= dom_id(comment) %>" class="chat-message">
  <div class="chat-message__meta">
    <span class="fw-bold"><%= comment.user.name %></span>
    <span><%= comment.created_at.in_time_zone(comment.user.school.time_zone) %></span>
  </div>
  <div class="chat-bubble chat-bubble--reply">
    <%= simple_format(h(comment.body), class: "mb-0") %>
  </div>
</div>
