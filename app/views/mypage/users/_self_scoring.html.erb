<h2>Self scoring</h2>
<% if @lessons&.length == 0 %>
No lessons.
<% else %>
  <div class="form-group" data-controller="collapse-persist">
    <%= form_with url: mypage_submission_path(),
                  method: :patch do |f| %>
      <%= render @lessons %>
      <div>
        <%= f.submit "Submit", class: "btn btn-primary my-3" %>
      </div>
    <% end %>
  </div>
<% end %>
